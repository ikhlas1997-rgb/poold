{
  "expo": {
    "name": "PoolD",
    "slug": "poold",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000719"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.poold.app",
      "config": {
        "googleMapsApiKey": "AIzaSyAnEzV8bjEuaHXn4qMhyD5TkLm_UOUhG8Y"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PoolD uses your location to find nearby rides and set pick-up points.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "PoolD uses your location to show your position during active rides."
      }
    },
    "android": {
      "package": "com.poold.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/icon.png",
        "backgroundColor": "#000719"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAnEzV8bjEuaHXn4qMhyD5TkLm_UOUhG8Y"
        }
      }
    },
    "web": {
      "favicon": "./assets/logo/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PoolD uses your location to match you with nearby rides."
        }
      ]
    ],
    "scheme": "poold",
    "extra": {
      "googleMapsApiKey": "AIzaSyAnEzV8bjEuaHXn4qMhyD5TkLm_UOUhG8Y"
    }
  }
}